# syntax=docker/dockerfile:1

########################  installer + builder stage  ########################
FROM oven/bun:1 AS builder
ENV CI=1
ARG NODE_ENV
WORKDIR /repo

COPY . .
RUN bun install --frozen-lockfile -F @hebo/mcp
RUN bun run -F @hebo/mcp build $( [ "$NODE_ENV" = "production" ] && echo "-- --production" )

########################  runner stage  ########################
FROM gcr.io/distroless/base
WORKDIR /app

COPY --from=builder /repo/apps/mcp/dist/server .

EXPOSE 3003
USER nonroot:nonroot
CMD ["/app/server"]
