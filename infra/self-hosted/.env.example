# Hebo self-hosted configuration
# Copy this file to .env and adjust as needed.
# All values have sensible defaults — no required configuration.

# ── Auth ──
# Auto-generated and persisted on first boot if left blank.
AUTH_SECRET=

# ── Ports ──
# Override default ports if needed.
# CONSOLE_PORT=8520
# API_PORT=8521
# GATEWAY_PORT=8522
# AUTH_PORT=8523
# MCP_PORT=8524

# ── Database ──
# Override to use an external Postgres instance.
# DATABASE_URL=postgresql://postgres:password@postgres:5432/hebo

# ── OAuth (optional — leave blank to use email + password) ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── SMTP (optional — leave blank to use email + password) ──
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── LLM Providers (optional — users can bring their own keys per agent) ──
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# VOYAGE_API_KEY=
