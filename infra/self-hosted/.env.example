# Hebo self-hosted configuration
# Copy this file to .env and adjust as needed.
# All values have sensible defaults — no required configuration.

# ── Auth ──
# Auto-generated and persisted on first boot if left blank.
# AUTH_SECRET=

# ── Database ──
# Override to use an external Postgres instance.
# POSTGRES_URL=postgresql://user:pass@host:5432/hebo
# Override to use an external GreptimeDB instance.
# GREPTIME_HOST=greptimedb

# ── OAuth (optional — email + password always works, with or without OAuth) ──
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ── SMTP (optional — required for password-less email login and invitations) ──
# SMTP_HOST=          SMTP server hostname
# SMTP_PORT=          SMTP server port (e.g. 587)
# SMTP_USER=          SMTP username
# SMTP_PASS=          SMTP password
# SMTP_FROM=          Sender address (e.g. noreply@example.com)

# ── LLM Providers (optional — users can bring their own keys per agent) ──
# OPENAI_API_KEY=             OpenAI API key
# ANTHROPIC_API_KEY=          Anthropic API key
# GROQ_API_KEY=               Groq API key
# VOYAGE_API_KEY=             Voyage AI API key
# FOUNDRY_API_KEY=            Azure AI Foundry API key
# FOUNDRY_RESOURCE_NAME=      Azure AI Foundry resource name
# BEDROCK_REGION=             AWS region for Bedrock (e.g. us-east-1)
# BEDROCK_ROLE_ARN=           IAM role ARN for Bedrock cross-account access
# VERTEX_LOCATION=            Google Cloud region (e.g. us-central1)
# VERTEX_PROJECT=             Google Cloud project ID
# VERTEX_SERVICE_ACCOUNT_EMAIL=  Service account for Vertex AI
# VERTEX_AWS_PROVIDER_AUDIENCE=  Workload Identity Federation audience

# ── BYOK Configuration ──
# ENFORCE_BYOK=false          When true, users must provide their own API keys
# FREE_MODEL_IDS=             Comma-separated model IDs that don't require BYOK
