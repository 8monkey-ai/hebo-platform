{
  "name": "hebo",
  "version": "0.3.19",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --workspaces --if-present --sequential build",
    "clean": "git clean -fdx -e '.env*'",
    "db:migrate": "bun run --workspaces --if-present --sequential db:migrate",
    "db:reset": "docker compose rm -sf greptimedb && docker volume rm hebo_greptimedb-data -f && docker compose up -d greptimedb && bun run --workspaces --if-present --sequential db:reset",
    "predev": "bun run --workspaces --if-present --sequential predev",
    "dev": "bun run --workspaces --if-present --parallel dev",
    "dev:infra:up": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "format": "oxfmt .",
    "format:staged": "oxfmt --no-error-on-unmatched-pattern",
    "lint": "oxlint",
    "lint:staged": "oxlint --fix",
    "lint:deps": "check-dependency-version-consistency .",
    "prepare": "test -n \"$CI\" || lefthook install",
    "secret": "bun run scripts/secrets.ts",
    "test": "bun run --workspaces --if-present --parallel test"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "check-dependency-version-consistency": "^6.0.0",
    "lefthook": "^2.0.15",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "sst": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": "^1.3.10"
  },
  "packageManager": "bun@1.3.10",
  "catalog": {
    "@opentelemetry/api": "^1.9.0",
    "ai": "^6.0.105",
    "@ai-sdk/provider-utils": "^4.0.17",
    "@base-ui/utils": "^0.2.5",
    "@base-ui/react": "^1.2.0",
    "@better-auth/api-key": "^1.5.3",
    "@conform-to/react": "^1.15.1",
    "@conform-to/zod": "^1.15.1",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "1.4.5",
    "@elysiajs/openapi": "^1.4.13",
    "@elysiajs/opentelemetry": "^1.4.10",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@prisma/instrumentation": "^7.4.2",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "^1.4.27",
    "lucide-react": "^0.576.0",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sst": "^3.17.38",
    "tailwindcss": "^4.1.18",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.5"
  }
}
