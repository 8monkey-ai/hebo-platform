{
  "name": "hebo",
  "version": "0.6.4",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --workspaces --if-present --sequential build",
    "clean": "git clean -fdx -e '.env*'",
    "db:migrate": "bun run --workspaces --if-present --sequential db:migrate",
    "db:reset": "bun run --workspaces --if-present --sequential db:reset",
    "predev": "bun run --workspaces --if-present --sequential predev",
    "dev": "bun run --workspaces --if-present --parallel dev",
    "dev:infra:up": "docker compose -f infra/dev/docker-compose.yaml up -d",
    "dev:infra:down": "docker compose -f infra/dev/docker-compose.yaml down",
    "format": "oxfmt .",
    "format:staged": "oxfmt --no-error-on-unmatched-pattern",
    "lint": "oxlint",
    "lint:staged": "oxlint --fix",
    "lint:deps": "check-dependency-version-consistency .",
    "prepare": "test -n \"$CI\" || lefthook install",
    "secret": "bun run scripts/secrets.ts",
    "test": "bun run --workspaces --if-present --parallel test",
    "pretypecheck": "bun run predev",
    "typecheck": "bun run --workspaces --if-present --parallel typecheck"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "check-dependency-version-consistency": "^6.0.0",
    "lefthook": "^2.0.15",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "sst": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": "^1.3.12"
  },
  "packageManager": "bun@1.3.12",
  "catalog": {
    "@opentelemetry/api": "^1.9.0",
    "ai": "^6.0.105",
    "@ai-sdk/provider-utils": "^4.0.17",
    "@base-ui/utils": "^0.2.5",
    "@base-ui/react": "^1.2.0",
    "@better-auth/api-key": "^1.6.5",
    "@conform-to/react": "^1.15.1",
    "@conform-to/zod": "^1.15.1",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/opentelemetry": "github:turisanapo/opentelemetry#fork/main",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-pg": "^0.66.0",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@better-auth/prisma-adapter": "^1.6.5",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "^1.4.28",
    "lucide-react": "^0.576.0",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0",
    "@react-router/dev": "^7.14.0",
    "@react-router/fs-routes": "^7.14.0",
    "@react-router/node": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "sst": "^4.7.3",
    "tailwindcss": "^4.1.18",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.0",
    "lru-cache": "^11.2.5",
    "zod": "^4.3.5"
  }
}
