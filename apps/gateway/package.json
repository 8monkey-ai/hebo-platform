{
  "name": "@hebo/gateway",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "bun build src/index.ts --minify-whitespace --minify-syntax --keep-names --target=bun --outdir dist $([ \"$NODE_ENV\" = production ] && echo '--production')",
    "clean": "git clean -fdx -e '.env*' .",
    "dev": "bun --hot src/index.ts",
    "format": "oxfmt .",
    "lint": "oxlint",
    "test": "bun test",
    "typecheck": "oxlint --type-aware --type-check",
    "prestart": "bun run build",
    "start": "bun dist/index.js"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^1.0.21",
    "@ai-sdk/amazon-bedrock": "^4.0.100",
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/azure": "^3.0.59",
    "@ai-sdk/deepinfra": "^2.0.49",
    "@ai-sdk/deepseek": "^2.0.32",
    "@ai-sdk/fireworks": "^2.0.50",
    "@ai-sdk/google-vertex": "^4.0.118",
    "@ai-sdk/groq": "^3.0.38",
    "@ai-sdk/moonshotai": "^2.0.20",
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/togetherai": "^2.0.49",
    "@ai-sdk/xai": "^3.0.87",
    "@aws-sdk/client-bedrock": "^3.985.0",
    "@aws-sdk/credential-providers": "^3.985.0",
    "@elysiajs/cors": "catalog:",
    "@elysiajs/openapi": "catalog:",
    "@elysiajs/opentelemetry": "catalog:",
    "@hebo-ai/gateway": "0.11.3",
    "@hebo/api": "workspace:*",
    "@hebo/shared-api": "workspace:*",
    "@opentelemetry/api": "catalog:",
    "elysia": "catalog:",
    "lru-cache": "catalog:",
    "voyage-ai-provider": "^3.0.0",
    "zhipu-ai-provider": "^0.3.0"
  },
  "devDependencies": {
    "@hebo/typescript-config": "workspace:*",
    "@types/bun": "catalog:"
  }
}
