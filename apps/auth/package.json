{
  "name": "@hebo/auth",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "prebuild": "bun run db generate",
    "build": "bun build src/index.ts --compile --minify-whitespace --minify-syntax --keep-names --target=bun --outfile dist/server",
    "clean": "git clean -fdx -e '.env*' .",
    "generate-schema": "bunx --bun @better-auth/cli generate --config src/better-auth.ts",
    "db": "prisma",
    "predev": "test -d src/generated || bun run db generate",
    "dev": "bun --hot src/index.ts",
    "format": "oxfmt .",
    "lint": "oxlint",
    "type-check": "tsc --noEmit",
    "prestart": "bun run build",
    "start": "./dist/server"
  },
  "dependencies": {
    "@elysiajs/cors": "catalog:",
    "@elysiajs/opentelemetry": "catalog:",
    "@hebo/shared-api": "workspace:*",
    "@prisma/client": "catalog:",
    "@upyo/core": "^0.4.0",
    "@upyo/smtp": "^0.4.0",
    "better-auth": "catalog:",
    "elysia": "catalog:"
  },
  "devDependencies": {
    "@hebo/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "prisma": "catalog:"
  }
}
