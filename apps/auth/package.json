{
  "name": "@hebo/auth",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "prebuild": "bun run db generate",
    "build": "bun build src/index.ts --minify-whitespace --minify-syntax --keep-names --target=bun --outdir dist $([ \"$NODE_ENV\" = production ] && echo '--production')",
    "clean": "git clean -fdx -e '.env*' .",
    "generate-schema": "bunx --bun @better-auth/cli generate --config src/better-auth.ts",
    "db": "prisma",
    "db:migrate": "bun run db migrate dev",
    "db:reset": "bun run db migrate reset --force",
    "predev": "test -d src/generated || bun run db generate",
    "dev": "bun --hot src/index.ts",
    "format": "oxfmt .",
    "lint": "oxlint",
    "typecheck": "bun run predev && oxlint --type-aware --type-check",
    "prestart": "bun run build",
    "start": "bun dist/index.js"
  },
  "dependencies": {
    "@better-auth/api-key": "catalog:",
    "@better-auth/prisma-adapter": "catalog:",
    "@elysia/cors": "catalog:",
    "@elysia/opentelemetry": "catalog:",
    "@hebo/shared-api": "workspace:*",
    "@prisma/client": "catalog:",
    "@upyo/core": "^0.4.0",
    "@upyo/smtp": "^0.4.0",
    "better-auth": "catalog:",
    "elysia": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hebo/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "prisma": "catalog:"
  }
}
