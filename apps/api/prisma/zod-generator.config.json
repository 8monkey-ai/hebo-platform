{
  "mode": "custom",
  "zodImportTarget": "v4",
  "dateTimeStrategy": "date",
  "emit": {
    "objects": false,
    "crud": false
  },
  "globalExclusions": {
    "pure": ["id", "deleted_by", "deleted_at", "organization_id"],
    "input": [
      "id",
      "slug",
      "created_by",
      "created_at",
      "updated_by",
      "updated_at",
      "deleted_by",
      "deleted_at",
      "organization_id",
      "team_id"
    ]
  },
  "variants": {
    "pure": {
      "enabled": true
    },
    "input": {
      "enabled": true
    },
    "result": {
      "enabled": false
    }
  },
  "models": {
    "agents": {
      "variants": {
        "pure": {
          "excludeFields": ["branches"]
        },
        "input": {
          "excludeFields": ["branches"]
        }
      }
    },
    "branches": {
      "variants": {
        "pure": {
          "excludeFields": ["agent", "models"]
        },
        "input": {
          "excludeFields": ["agent", "agent_slug", "models"]
        }
      }
    }
  }
}
