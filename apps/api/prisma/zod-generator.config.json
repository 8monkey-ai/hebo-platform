{
  "mode": "custom",
  "zodImportTarget": "v4",
  "dateTimeStrategy": "date",
  "variants": {
    "pure": {
      "enabled": true,
      "excludeFields": ["id", "deleted_by", "deleted_at", "organization_id", "agent", "branches"]
    },
    "input": {
      "enabled": true,
      "excludeFields": [
        "id",
        "slug",
        "agent_slug",
        "created_by",
        "created_at",
        "updated_by",
        "updated_at",
        "deleted_by",
        "deleted_at",
        "organization_id",
        "team_id"
      ]
    },
    "result": {
      "enabled": false
    }
  }
}
