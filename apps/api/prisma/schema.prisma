// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

generator json {
  provider     = "prisma-json-types-generator"
  clientOutput = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model workspaces {
  id      String    @id @default(uuid(7)) @db.Uuid
  slug    String
  name    String
  team_id String
  presets presets[]

  // Common audit fields — injected by Prisma extension.
  // @default("") keeps create inputs optional, results non-nullable.
  created_by      String    @default("")
  created_at      DateTime  @default(now())
  updated_by      String    @default("")
  updated_at      DateTime  @updatedAt
  deleted_by      String?
  deleted_at      DateTime?
  organization_id String    @default("")

  @@unique([organization_id, slug])
}

model presets {
  id           String     @id @default(uuid(7)) @db.Uuid
  workspace_id String     @db.Uuid
  name         String
  slug         String
  model        String
  workspace    workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  // Common audit fields — injected by Prisma extension.
  // @default("") keeps create inputs optional, results non-nullable.
  created_by      String    @default("")
  created_at      DateTime  @default(now())
  updated_by      String    @default("")
  updated_at      DateTime  @updatedAt
  deleted_by      String?
  deleted_at      DateTime?
  organization_id String    @default("")

  @@unique([workspace_id, slug])
  @@index([organization_id, slug])
}

model provider_configs {
  id            String @id @default(uuid(7)) @db.Uuid
  provider_slug String
  /// [ProviderConfig]
  value         Json

  // Common audit fields — injected by Prisma extension.
  // @default("") keeps create inputs optional, results non-nullable.
  created_by      String    @default("")
  created_at      DateTime  @default(now())
  updated_by      String    @default("")
  updated_at      DateTime  @updatedAt
  deleted_by      String?
  deleted_at      DateTime?
  organization_id String    @default("")
}
