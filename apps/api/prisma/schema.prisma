// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

generator json {
  provider     = "prisma-json-types-generator"
  clientOutput = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model agents {
  id       String     @id @default(uuid(7)) @db.Uuid
  slug     String     @unique
  name     String
  branches branches[]

  // Common audit fields — injected by Prisma extension.
  // @default("") keeps create inputs optional, results non-nullable.
  created_by      String    @default("")
  created_at      DateTime  @default(now())
  updated_by      String    @default("")
  updated_at      DateTime  @updatedAt
  deleted_by      String?
  deleted_at      DateTime?
  organization_id String    @default("")
  team_id         String
}

model branches {
  id         String @id @default(uuid(7)) @db.Uuid
  slug       String
  agent_slug String
  name       String
  /// [ModelConfig]
  models     Json[] @default([])
  agent      agents @relation(fields: [agent_slug], references: [slug], onDelete: Cascade)

  // Common audit fields — injected by Prisma extension.
  // @default("") keeps create inputs optional, results non-nullable.
  created_by      String    @default("")
  created_at      DateTime  @default(now())
  updated_by      String    @default("")
  updated_at      DateTime  @updatedAt
  deleted_by      String?
  deleted_at      DateTime?
  organization_id String    @default("")

  @@unique([agent_slug, slug])
}

model provider_configs {
  id            String @id @default(uuid(7)) @db.Uuid
  provider_slug String
  /// [ProviderConfig]
  value         Json

  // Common audit fields — injected by Prisma extension.
  // @default("") keeps create inputs optional, results non-nullable.
  created_by      String    @default("")
  created_at      DateTime  @default(now())
  updated_by      String    @default("")
  updated_at      DateTime  @updatedAt
  deleted_by      String?
  deleted_at      DateTime?
  organization_id String    @default("")
}
