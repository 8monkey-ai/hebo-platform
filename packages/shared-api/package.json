{
  "name": "@hebo/shared-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": [
    "lib/otel.ts"
  ],
  "exports": {
    "./*": "./*.ts"
  },
  "scripts": {
    "clean": "git clean -fdx -e '.env*' .",
    "db:migrate": "docker exec greptime curl -sS -X POST 'http://localhost:4000/v1/sql?db=information_schema' -d 'sql=CREATE DATABASE IF NOT EXISTS public'",
    "db:reset": "docker exec greptime curl -sS -X POST 'http://localhost:4000/v1/sql?db=information_schema' -d 'sql=DROP DATABASE IF EXISTS public'",
    "format": "oxfmt .",
    "lint": "oxlint",
    "test": "bun test",
    "typecheck": "oxlint --type-aware --type-check"
  },
  "dependencies": {
    "@8monkey/opentelemetry-instrumentation-bun-sql": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/api-logs": "catalog:",
    "@opentelemetry/exporter-logs-otlp-proto": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-proto": "catalog:",
    "@opentelemetry/exporter-trace-otlp-proto": "catalog:",
    "@opentelemetry/instrumentation": "catalog:",
    "@opentelemetry/instrumentation-pg": "catalog:",
    "@opentelemetry/otlp-exporter-base": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-logs": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@sindresorhus/slugify": "^3.0.0",
    "better-auth": "catalog:",
    "crypto-random-string": "^5.0.0"
  },
  "devDependencies": {
    "@hebo/typescript-config": "workspace:*",
    "@types/bun": "catalog:"
  },
  "peerDependencies": {
    "@elysia/opentelemetry": "catalog:",
    "elysia": "catalog:",
    "sst": "catalog:"
  }
}
